# Example .env file for MicroPython projects
# Copy this file to .env and fill in your actual values

# WiFi Configuration
WIFI_SSID=your_network_name
WIFI_PASSWORD=your_secure_password

# Device Configuration
HOSTNAME=my-device
DEVICE_ID=device-001

# API Configuration (if using external services)
API_ENDPOINT=https://api.example.com
API_KEY=your-api-key-here
API_TIMEOUT=30

# MQTT Configuration (if using MQTT)
MQTT_BROKER=broker.example.com
MQTT_PORT=1883
MQTT_USER=mqtt_username
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC=sensors/device001

# Sensor Configuration
SENSOR_READ_INTERVAL=60
TEMPERATURE_OFFSET=0.0
HUMIDITY_OFFSET=0.0

# Debug Settings
DEBUG=false
LOG_LEVEL=INFO

# Comments are supported
# Empty lines are ignored
# Inline comments work too: KEY=value # this is ignored
